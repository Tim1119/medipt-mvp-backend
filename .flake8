[flake8]
max-line-length = 88
exclude =
    .git,
    __pycache__,
    migrations,
    venv,
    env,
    .venv,
    .env,
    build,
    dist,
    *.egg-info,
    node_modules
ignore = E203, E501, W503, F403, F405
per-file-ignores =
    __init__.py:F401
    settings/*.py:E402,F403,F405
    */settings.py:E402,F403,F405
    */settings/*.py:E402,F403,F405
